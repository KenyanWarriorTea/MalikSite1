# MalikSite1 Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
# Default: postgresql://user:password@db:5432/tasks_db
# For local development: postgresql://user:password@localhost:5432/tasks_db
DATABASE_URL=postgresql://user:password@db:5432/tasks_db

# Judge0 API Configuration
# Default: http://judge0:2358 (when running in Docker)
# For local development: http://localhost:2358
JUDGE0_URL=http://judge0:2358

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Access Codes (CHANGE THESE IN PRODUCTION!)
TEACHER_CODE=teacher123
STUDENT_CODE=student123
